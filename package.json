{
  "name": "tradtube",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run copy-ffmpeg-worker && vite",
    "build": "npm run copy-ffmpeg-worker && vite build",
    "preview": "vite preview",
    "test": "vitest --config vitest.config.js",
    "test:run": "vitest run --config vitest.config.js",
    "copy-ffmpeg-worker": "cp node_modules/@ffmpeg/ffmpeg/dist/esm/worker.js public/ffmpeg-core-worker.js"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@solid-primitives/i18n": "^2.2.1",
    "@solidjs/router": "^0.16.1",
    "@sqlite.org/sqlite-wasm": "3.51.2-build8",
    "@supabase/supabase-js": "^2.39.0",
    "abcjs": "^6.6.2",
    "lucide-solid": "^1.16.0",
    "pg": "^8.21.0",
    "solid-js": "^1.8.11"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "autoprefixer": "^10.4.16",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.10",
    "vite-plugin-solid": "^2.8.0",
    "vitest": "^4.1.8"
  }
}
